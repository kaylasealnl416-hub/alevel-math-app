{
  "name": "alevel-backend",
  "version": "1.0.0",
  "description": "A-Level AI教师后端服务",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.js",
    "start": "bun src/index.js",
    "db:test": "bun src/db/test-connection.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.js",
    "check:env": "node check-env.js",
    "check:production": "node check-production.js",
    "seed:test": "bun seed-test-data.js",
    "test": "bun test tests/unit",
    "test:unit": "bun test tests/unit",
    "test:db": "bun src/db/test-connection.js",
    "test:integration": "bun tests/run-all-tests.js --integration",
    "test:data": "bun tests/run-all-tests.js --data",
    "test:all": "bun tests/run-all-tests.js --all"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.5",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@hono/node-server": "^1.19.11",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "hono-rate-limiter": "^0.5.3",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "multer": "^2.1.1",
    "pdf.js-extract": "^0.2.1",
    "postgres": "^3.4.8",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
