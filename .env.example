# ============================================================
# Frontend Environment Variables
# ============================================================

# Backend API URL
# Development: http://localhost:4000
# Production: https://alevel-math-app-production-6e22.up.railway.app
VITE_API_URL=http://localhost:4000

# Enable Backend API (set to 'true' to use backend API)
VITE_USE_API=true

# AI Provider (for direct API calls, if needed)
# Options: 'anthropic' | 'minimax' | 'zhipu'
VITE_AI_PROVIDER=anthropic
